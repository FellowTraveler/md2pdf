#!/bin/bash
# -*- mode: python -*-
''':'
exec "$HOME/.md2pdf-venv/bin/python3" "$0" "$@"
'''

import datetime
import os
import pathlib
import sys
from datetime import date
from pathlib import Path

SUPPORTED = {".aac", ".mp3", ".m4a", ".wav", ".ogg", ".flac", ".opus", ".wma", ".caf"}


def load_env():
    env_path = Path.home() / ".config" / "md2pdf" / ".env"
    if not env_path.exists():
        return
    for line in env_path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" in line:
            key, _, value = line.partition("=")
            v = value.strip().strip('"').strip("'")
            os.environ.setdefault(key.strip(), v)


def fmt_duration(seconds):
    seconds = int(seconds)
    h = seconds // 3600
    m = (seconds % 3600) // 60
    s = seconds % 60
    if h:
        return f"{h}:{m:02d}:{s:02d}"
    return f"{m}:{s:02d}"


def fmt_ts(seconds):
    seconds = int(seconds)
    h = seconds // 3600
    m = (seconds % 3600) // 60
    s = seconds % 60
    if h:
        return f"{h:02d}:{m:02d}:{s:02d}"
    return f"{m:02d}:{s:02d}"


def whisper_transcribe(path, model_size="base"):
    from faster_whisper import WhisperModel
    model = WhisperModel(model_size, device="auto", compute_type="auto")
    segments_iter, info = model.transcribe(str(path), beam_size=5, word_timestamps=False)
    segments = list(segments_iter)
    return segments, info.duration


def build_markdown_whisper_only(path, segments, duration, model_size):
    name = Path(path).name
    today = date.today().isoformat()
    lines = [
        f"# Transcript: {name}",
        "",
        f"**Date:** {today}",
        f"**Duration:** {fmt_duration(duration)}",
        f"**Transcribed by:** Whisper ({model_size})",
        "",
        "---",
        "",
    ]
    for seg in segments:
        ts = fmt_ts(seg.start)
        text = seg.text.strip()
        if text:
            lines.append(f"`[{ts}]` {text}")
            lines.append("")
    return "\n".join(lines)


def build_markdown_diarized(path, speaker_segments, duration, method):
    filename = pathlib.Path(path).name
    date_str = datetime.date.today().isoformat()
    duration_str = fmt_duration(duration)

    header = f"""# Transcript: {filename}

**Date:** {date_str}
**Duration:** {duration_str}
**Transcribed by:** {method}

---

"""
    speakers = {s for s, _, _, _ in speaker_segments}
    if len(speakers) <= 1:
        text = " ".join(" ".join(t.split()) for _, _, _, t in speaker_segments if t.strip())
        return header + text + "\n"

    lines = []
    for speaker, start, end, text in speaker_segments:
        text = " ".join(text.split())
        if not text:
            continue
        lines.append(f"**[{speaker}]** `{fmt_ts(start)}`\n\n{text}")

    return header + "\n\n".join(lines) + "\n"


def transcribe_elevenlabs(path):
    from elevenlabs.client import ElevenLabs
    api_key = os.environ.get("ELEVENLABS_API_KEY")
    client = ElevenLabs(api_key=api_key)
    with open(path, "rb") as f:
        result = client.speech_to_text.convert(
            file=f,
            model_id="scribe_v1",
            diarize=True,
            timestamps_granularity="word",
        )
    segments = []
    cur_spk, cur_start, cur_end, cur_text = None, 0.0, 0.0, ""
    for word in (result.words or []):
        spk = getattr(word, "speaker_id", None) or "Speaker A"
        w = " ".join(word.text.split())
        if spk != cur_spk:
            if cur_text:
                segments.append((cur_spk, cur_start, cur_end, cur_text))
            cur_spk, cur_start, cur_end, cur_text = spk, float(word.start), float(word.end), w
        else:
            cur_end = float(word.end)
            cur_text += " " + w
    if cur_text:
        segments.append((cur_spk, cur_start, cur_end, cur_text))
    duration = float(result.words[-1].end) if result.words else 0.0
    return segments, duration


def _run_pyannote(path, hf_token):
    from pyannote.audio import Pipeline
    pipeline = Pipeline.from_pretrained(
        "pyannote/speaker-diarization-3.1",
        token=hf_token,
    )
    result = pipeline(str(path))
    return result.speaker_diarization if hasattr(result, "speaker_diarization") else result


def _merge_whisper_diarization(path, model_size, diarization):
    from faster_whisper import WhisperModel
    model = WhisperModel(model_size, device="auto", compute_type="auto")
    whisper_segs, info = model.transcribe(str(path), beam_size=5, word_timestamps=True)

    def speaker_at(t):
        for turn, _, speaker in diarization.itertracks(yield_label=True):
            if turn.start <= t <= turn.end:
                return speaker
        return "Speaker A"

    segments = []
    cur_spk, cur_start, cur_end, cur_text = None, 0.0, 0.0, ""
    for seg in whisper_segs:
        for word in (seg.words or []):
            mid = (word.start + word.end) / 2.0
            spk = speaker_at(mid)
            if spk != cur_spk:
                if cur_text.strip():
                    segments.append((cur_spk, cur_start, cur_end, cur_text.strip()))
                cur_spk, cur_start, cur_end, cur_text = spk, word.start, word.end, word.text
            else:
                cur_end = word.end
                cur_text += " " + word.text
    if cur_text.strip():
        segments.append((cur_spk, cur_start, cur_end, cur_text.strip()))
    return segments, info.duration


def build_markdown_raw(path, segments, duration, model_size):
    name = Path(path).name
    today = date.today().isoformat()
    text = " ".join(seg.text.strip() for seg in segments if seg.text.strip())
    return (f"# Transcript: {name}\n\n"
            f"**Date:** {today}\n"
            f"**Duration:** {fmt_duration(duration)}\n"
            f"**Transcribed by:** Whisper ({model_size})\n\n---\n\n{text}\n")


def process_file(path):
    p = Path(path)
    if p.suffix.lower() not in SUPPORTED:
        print(f"Skipping unsupported file type: {p.name}", file=sys.stderr)
        return

    out_path = p.with_suffix(".md")
    print(f"Transcribing: {p.name} -> {out_path.name}", file=sys.stderr)

    el_key = os.environ.get("ELEVENLABS_API_KEY")
    hf_token = os.environ.get("HUGGINGFACE_TOKEN")
    model_size = os.environ.get("WHISPER_MODEL", "base")

    try:
        # Step 1: always run Whisper (fast, local, free)
        whisper_segs, duration = whisper_transcribe(p, model_size)

        # Step 2: if HF token, check speaker count locally before deciding on cloud
        if hf_token:
            try:
                diarization = _run_pyannote(p, hf_token)
                n_speakers = len({spk for _, _, spk in diarization.itertracks(yield_label=True)})
            except Exception as e:
                print(f"Warning: speaker detection failed ({e}), using Whisper-only", file=sys.stderr)
                n_speakers = 1

            if n_speakers <= 1:
                md = build_markdown_raw(p, whisper_segs, duration, model_size)
            elif el_key:
                segs, dur = transcribe_elevenlabs(p)
                md = build_markdown_diarized(p, segs, dur, "ElevenLabs (scribe_v1)")
            else:
                segs, dur = _merge_whisper_diarization(p, model_size, diarization)
                md = build_markdown_diarized(p, segs, dur, f"Whisper ({model_size}) + speaker diarization")

        elif el_key:
            # No local speaker check available — let ElevenLabs decide
            segs, dur = transcribe_elevenlabs(p)
            md = build_markdown_diarized(p, segs, dur, "ElevenLabs (scribe_v1)")

        else:
            md = build_markdown_whisper_only(p, whisper_segs, duration, model_size)

    except Exception as e:
        msg = str(e)
        error_md = f"# Transcription Failed: {p.name}\n\n**Date:** {datetime.date.today().isoformat()}\n\n**Error:**\n\n```\n{msg}\n```\n"
        out_path.write_text(error_md, encoding="utf-8")
        print(f"Error transcribing {p.name}: {msg}", file=sys.stderr)
        os.system(f'osascript -e \'display notification "See {out_path.name} for details" with title "Transcription Failed"\'')
        sys.exit(1)

    out_path.write_text(md, encoding="utf-8")
    os.system(f'osascript -e \'display notification "Saved: {out_path.name}" with title "Transcription Complete"\'')
    print(f"Saved: {out_path}", file=sys.stderr)


def main():
    if len(sys.argv) < 2:
        print(f"Usage: {Path(sys.argv[0]).name} <audio_file> [...]", file=sys.stderr)
        sys.exit(1)
    load_env()
    for arg in sys.argv[1:]:
        process_file(arg)


if __name__ == "__main__":
    main()
