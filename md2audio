#!/bin/bash
# -*- mode: python -*-
''':'
exec "$HOME/.md2pdf-venv/bin/python3" "$0" "$@"
'''

import os
import re
import subprocess
import sys
import tempfile
from pathlib import Path

CURATED_VOICES = [
    ("David (default) — Deep, gravelly", "0hh7H4ZVAtaGpm1VZyEN"),
    ("Rachel — Calm, professional",       "21m00Tcm4TlvDq8ikWAM"),
    ("Adam — Masculine, American",        "pNInz6obpgDQGcFmaJgB"),
    ("Antoni — Warm, conversational",     "ErXwobaYiN019PkySvjV"),
    ("Josh — Young, energetic",           "TxGEqnHWrfWFTfGW9XjX"),
    ("Bella — Soft, feminine",            "EXAVITQu4vr4xnSDxMaL"),
]


def load_env():
    env_path = Path.home() / ".config" / "md2pdf" / ".env"
    if not env_path.exists():
        return
    for line in env_path.read_text().splitlines():
        line = line.strip()
        if not line or line.startswith("#"):
            continue
        if "=" in line:
            key, _, value = line.partition("=")
            os.environ.setdefault(key.strip(), value.strip().strip('"').strip("'"))


def osascript_run(script):
    result = subprocess.run(["osascript", "-e", script], capture_output=True, text=True)
    return result.stdout.strip(), result.returncode


def error_dialog(message):
    safe = message.replace('"', '\\"')
    osascript_run(
        f'display dialog "{safe}" with title "Create Audio Narration" '
        f'buttons {{"OK"}} default button "OK" with icon stop'
    )


def choose_from_list(title, prompt, items, default=None):
    items_str = ", ".join(f'"{item}"' for item in items)
    default_str = f' default items {{"{default}"}}' if default else ""
    script = (
        f'choose from list {{{items_str}}} '
        f'with title "{title}" with prompt "{prompt}"{default_str}'
    )
    out, code = osascript_run(script)
    if code != 0 or out == "false":
        return None
    return out


def choose_mode():
    options = [
        "Exact transcript — narrate word for word",
        "Summary narration — AI condenses key points first",
    ]
    chosen = choose_from_list(
        "Create Audio Narration", "Choose narration style:", options, options[0]
    )
    if chosen is None:
        sys.exit(0)
    return "summary" if chosen.startswith("Summary") else "exact"


def _search_elevenlabs_voice(api_key):
    script = (
        'display dialog "Search ElevenLabs voices:" with title "Voice Search" '
        'default answer "" buttons {"Cancel", "Search"} default button "Search"'
    )
    out, code = osascript_run(script)
    if code != 0 or "Cancel" in out:
        sys.exit(0)
    query = ""
    for part in out.split(", "):
        if part.startswith("text returned:"):
            query = part[len("text returned:"):]
    if not query:
        sys.exit(0)

    from elevenlabs.client import ElevenLabs
    client = ElevenLabs(api_key=api_key)
    all_voices = client.voices.get_all().voices
    matches = [v for v in all_voices if query.lower() in v.name.lower()][:20]
    if not matches:
        error_dialog(f"No voices found for '{query}'.")
        sys.exit(1)

    labels = [f"{v.name}" for v in matches]
    chosen = choose_from_list("Voice Search Results", f"Results for '{query}':", labels)
    if chosen is None:
        sys.exit(0)
    idx = labels.index(chosen)
    return "elevenlabs", matches[idx].voice_id


def choose_voice():
    el_key = os.environ.get("ELEVENLABS_API_KEY")
    default_voice_id = os.environ.get("ELEVENLABS_VOICE_ID", "0hh7H4ZVAtaGpm1VZyEN")
    default_label = next(
        (label for label, vid in CURATED_VOICES if vid == default_voice_id),
        CURATED_VOICES[0][0],
    )

    options = [label for label, _ in CURATED_VOICES]
    options.append("macOS system voice — Local, no API key needed")
    if el_key:
        options.append("Search ElevenLabs… — Find any voice by name")

    chosen = choose_from_list(
        "Create Audio Narration", "Choose a voice:", options, default_label
    )
    if chosen is None:
        sys.exit(0)

    if "macOS system voice" in chosen:
        return "macos", None
    if "Search ElevenLabs" in chosen:
        if not el_key:
            error_dialog("ElevenLabs API key required to search voices.")
            sys.exit(1)
        return _search_elevenlabs_voice(el_key)
    for label, vid in CURATED_VOICES:
        if label == chosen:
            return "elevenlabs", vid
    return "elevenlabs", default_voice_id


def process_file(path):
    p = Path(path)
    if p.suffix.lower() != ".md":
        error_dialog("Create Audio Narration only works with Markdown (.md) files.")
        sys.exit(1)
    print(f"Processing: {p.name}", file=sys.stderr)
    mode = choose_mode()
    provider, voice_id = choose_voice()
    print(f"Mode: {mode}, Provider: {provider}, Voice: {voice_id}", file=sys.stderr)


def main():
    if len(sys.argv) < 2:
        print(f"Usage: {Path(sys.argv[0]).name} <file.md>", file=sys.stderr)
        sys.exit(1)
    load_env()
    for arg in sys.argv[1:]:
        process_file(arg)


if __name__ == "__main__":
    main()
