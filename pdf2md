#!/usr/bin/env bash
#
# pdf2md - Convert PDF files to Markdown
#
# Usage: pdf2md <file.pdf>
#        pdf2md --help
#
# Requires: Python 3 with pymupdf4llm
#           For image-based PDFs: tesseract, pytesseract, Pillow
#

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color
BOLD='\033[1m'

show_help() {
    echo -e "${BOLD}pdf2md${NC} - Convert PDF files to Markdown"
    echo ""
    echo -e "${BOLD}USAGE:${NC}"
    echo "    pdf2md <file.pdf>     Convert PDF to Markdown"
    echo "    pdf2md --help         Show this help"
    echo ""
    echo -e "${BOLD}OUTPUT:${NC}"
    echo "    Creates a Markdown file with the same name as the input file."
    echo "    Example: README.pdf -> README.md"
    echo ""
    echo -e "${BOLD}REQUIRES:${NC}"
    echo "    Python 3 with pymupdf4llm"
    echo "    Install: pip3 install pymupdf4llm"
    echo ""
    echo -e "${BOLD}OCR SUPPORT (for image-based PDFs):${NC}"
    echo "    tesseract, pytesseract, Pillow"
    echo "    Install: brew install tesseract && pip3 install pytesseract Pillow"
    echo ""
    echo -e "${BOLD}AI CLEANUP (optional, for LLM-powered cleanup and diagram detection):${NC}"
    echo "    Set one of these in your environment, or add to ~/.config/md2pdf/env:"
    echo "      ANTHROPIC_API_KEY"
    echo "      OPENAI_API_KEY"
    echo "      OPENROUTER_API_KEY"
    echo ""
}

# Check arguments
if [[ $# -eq 0 ]] || [[ "$1" == "--help" ]] || [[ "$1" == "-h" ]]; then
    show_help
    exit 0
fi

# Check for Python 3
if ! command -v python3 &> /dev/null; then
    echo -e "${RED}Error: Python 3 not found.${NC}"
    exit 1
fi

# Check for pymupdf4llm in the dedicated venv
if ! "$HOME/.md2pdf-venv/bin/python3" -c "import pymupdf4llm" 2>/dev/null; then
    echo -e "${RED}Error: pymupdf4llm not found.${NC}"
    echo "Install: run ./install.sh to set up the Python venv"
    exit 1
fi

# Main conversion
INPUT_FILE="$1"

# Validate input file
if [[ ! -f "$INPUT_FILE" ]]; then
    echo -e "${RED}Error: File not found: $INPUT_FILE${NC}"
    exit 1
fi

if [[ "${INPUT_FILE##*.}" != "pdf" ]]; then
    echo -e "${RED}Error: Not a PDF file: $INPUT_FILE${NC}"
    exit 1
fi

# Generate output filename
OUTPUT_FILE="${INPUT_FILE%.pdf}.md"

echo -e "${BLUE}Converting:${NC} $INPUT_FILE"
echo -e "${BLUE}Output:${NC}     $OUTPUT_FILE"
echo ""

# Convert PDF to markdown using pymupdf4llm, with OCR fallback for image-based PDFs
OCR_USED=""
"$HOME/.md2pdf-venv/bin/python3" - "$INPUT_FILE" "$OUTPUT_FILE" << 'PYEOF'
import sys
import pymupdf4llm

input_file = sys.argv[1]
output_file = sys.argv[2]

md = pymupdf4llm.to_markdown(input_file, ignore_graphics=True)

# If text extraction found content, inject page markers and write
if md.strip():
    # pymupdf4llm uses \n-----\n between pages; inject <!-- page-N --> markers
    sep = "\n-----\n"
    parts = md.split(sep)
    marked = sep.join(f"<!-- page-{i+1} -->\n{p}" for i, p in enumerate(parts))
    with open(output_file, "w", encoding="utf-8") as f:
        f.write(marked)
    sys.exit(0)

# No text found — try OCR fallback
print("No text found in PDF, attempting OCR...", file=sys.stderr)
try:
    import pymupdf
    import pytesseract
    from PIL import Image
    import io
except ImportError as e:
    print(f"OCR dependencies not available: {e}", file=sys.stderr)
    print("Install: brew install tesseract && pip3 install pytesseract Pillow", file=sys.stderr)
    with open(output_file, "w", encoding="utf-8") as f:
        f.write("")
    sys.exit(0)

doc = pymupdf.open(input_file)
pages = []
for i, page in enumerate(doc):
    pix = page.get_pixmap(dpi=300)
    img = Image.open(io.BytesIO(pix.tobytes("png")))
    text = pytesseract.image_to_string(img)
    if text.strip():
        pages.append(text.strip())
    print(f"  OCR page {i + 1}/{len(doc)}", file=sys.stderr)
doc.close()

marked_pages = [f"<!-- page-{i+1} -->\n{p}" for i, p in enumerate(pages)]
md = "\n\n---\n\n".join(marked_pages)
with open(output_file, "w", encoding="utf-8") as f:
    f.write(md)

# Signal to the shell that OCR was used
with open("/tmp/pdf2md-ocr-used", "w") as f:
    f.write("1")
PYEOF

# Check if OCR was used for the status message
if [[ -f "/tmp/pdf2md-ocr-used" ]]; then
    OCR_USED="yes"
    rm -f "/tmp/pdf2md-ocr-used"
fi

# Load API keys if not already set in environment
if [[ -z "$ANTHROPIC_API_KEY" ]] && [[ -z "$OPENAI_API_KEY" ]] && [[ -z "$OPENROUTER_API_KEY" ]]; then
    if [[ -f "$HOME/.config/md2pdf/env" ]]; then
        source "$HOME/.config/md2pdf/env"
    elif [[ -f "$HOME/.config/pdf2md/env" ]]; then
        source "$HOME/.config/pdf2md/env"
    elif [[ -f "$HOME/.zshenv" ]]; then
        eval "$(grep -E 'ANTHROPIC_API_KEY|OPENAI_API_KEY|OPENROUTER_API_KEY' "$HOME/.zshenv" 2>/dev/null)" 2>/dev/null || true
    fi
fi

# LLM cleanup of extracted markdown
if [[ -n "$ANTHROPIC_API_KEY" ]] || [[ -n "$OPENAI_API_KEY" ]] || [[ -n "$OPENROUTER_API_KEY" ]]; then
    echo -e "${BLUE}Cleaning up output with LLM...${NC}"
    CLEANUP_TMP="${OUTPUT_FILE}.cleanup.tmp"
    "$HOME/.md2pdf-venv/bin/python3" - "$OUTPUT_FILE" "$CLEANUP_TMP" "$OCR_USED" << 'CLEANUP_PYEOF' || true
import sys, os
sys.path.insert(0, os.path.expanduser("~/.config/md2pdf"))
try:
    from llm_helper import text_complete, get_provider
except ImportError:
    sys.exit(0)

if not get_provider():
    sys.exit(0)

output_file = sys.argv[1]
cleanup_tmp = sys.argv[2]
ocr_used = sys.argv[3] if len(sys.argv) > 3 else ""

with open(output_file, "r", encoding="utf-8") as f:
    raw_md = f.read()

if not raw_md.strip():
    sys.exit(0)

if ocr_used:
    prompt = f"""You are a verbatim text reformatter. Reformat this raw OCR text into clean markdown.

CRITICAL RULES:
1. Keep ALL text VERBATIM — do NOT summarize, condense, or omit anything
2. Every sentence, code snippet, command, and data value in the input MUST appear in the output
3. Fix only OCR artifacts (garbled characters, broken words)
4. Remove exact duplicate paragraphs from overlapping page captures
5. Remove PDF artifacts: standalone page numbers (e.g. bare "1", "2" on their own line), headers/footers
6. Restore markdown formatting (headers, bold, italic, bullets, tables, code blocks)
7. Add language hints to code blocks where detectable (```bash, ```json, etc.)
8. Remove UI chrome (Show more/less buttons, spinners, navigation elements)
9. Preserve HTML comments of the form <!-- page-N --> exactly as-is — do not remove or alter them
10. Output ONLY the cleaned markdown, no preamble or explanation

You MUST NOT shorten, paraphrase, or summarize the text. The output should be approximately the same length as the input. If anything, ERR ON THE SIDE OF INCLUDING TOO MUCH rather than too little.

---
{raw_md}"""
else:
    prompt = f"""You are a verbatim text reformatter. Clean up this markdown extracted from a PDF.

CRITICAL RULES:
1. Keep ALL text VERBATIM — do NOT summarize, condense, or omit anything
2. Every sentence, code snippet, command, and data value in the input MUST appear in the output
3. Fix broken formatting from PDF extraction (mangled headers, lists, tables, code blocks)
4. Remove PDF artifacts: standalone page numbers (e.g. bare "1", "2" on their own line), headers/footers, unnecessary line breaks
5. Fix em-dash artifacts: replace ~~—~~ with — and ~~-~~ with - (these are PDF extraction glitches)
6. Fix heading hierarchy: the PDF often flattens all headings to H1 (#). Restore proper levels (H1 for title, H2 for major sections, H3 for subsections, etc.) based on context
7. Restore horizontal rules (---) where section dividers were lost or mangled
8. Add language hints to code blocks where detectable (```bash, ```json, etc.)
9. Restore proper markdown structure
10. Preserve HTML comments of the form <!-- page-N --> exactly as-is — do not remove or alter them
11. Output ONLY the cleaned markdown, no preamble or explanation

You MUST NOT shorten, paraphrase, or summarize the text. The output should be approximately the same length as the input. If anything, ERR ON THE SIDE OF INCLUDING TOO MUCH rather than too little.

---
{raw_md}"""

cleaned = text_complete(prompt, max_tokens=16384)
if cleaned:
    with open(cleanup_tmp, "w", encoding="utf-8") as f:
        f.write(cleaned)
CLEANUP_PYEOF
    if [[ -f "$CLEANUP_TMP" ]] && [[ -s "$CLEANUP_TMP" ]]; then
        mv "$CLEANUP_TMP" "$OUTPUT_FILE"
        echo -e "  ${GREEN}LLM cleanup complete${NC}"
    else
        rm -f "$CLEANUP_TMP"
        echo -e "  ${YELLOW}LLM cleanup failed, keeping raw output${NC}"
    fi
else
    echo -e "  ${YELLOW}Tip: Set ANTHROPIC_API_KEY, OPENAI_API_KEY, or OPENROUTER_API_KEY for LLM-powered cleanup${NC}"
fi

# Image extraction and diagram detection phase
if [[ -n "$ANTHROPIC_API_KEY" ]] || [[ -n "$OPENAI_API_KEY" ]] || [[ -n "$OPENROUTER_API_KEY" ]]; then
    echo -e "${BLUE}Extracting images from PDF...${NC}"
    "$HOME/.md2pdf-venv/bin/python3" - "$INPUT_FILE" "$OUTPUT_FILE" << 'IMAGE_PYEOF' || true
import sys, os

sys.path.insert(0, os.path.expanduser("~/.config/md2pdf"))
try:
    import pymupdf
    from llm_helper import vision_complete, get_provider
except ImportError as e:
    print(f"Skipping image extraction: {e}", file=sys.stderr)
    sys.exit(0)

if not get_provider():
    sys.exit(0)

input_file = sys.argv[1]
output_file = sys.argv[2]

base_name = os.path.splitext(os.path.basename(output_file))[0]
output_dir = os.path.dirname(os.path.abspath(output_file))

doc = pymupdf.open(input_file)
page_images = {}

DRAWING_THRESHOLD = 25
MIN_IMAGE_AREA = 1000

def classify_and_convert(image_bytes, media_type, img_filename, img_path):
    # Step 1: is it meaningful content worth including at all?
    worth_it = vision_complete(image_bytes, media_type,
        "Is this a meaningful image worth including in a document — "
        "such as a diagram, chart, photo, figure, or screenshot of actual UI content? "
        "Answer only 'yes' or 'no'. Answer 'no' for: screenshots of plain text, "
        "decorative borders, page backgrounds, or blank/near-blank images.",
        max_tokens=10)
    if not worth_it or not worth_it.strip().lower().startswith('y'):
        print(f"  Skipping (not meaningful): {img_filename}", file=sys.stderr)
        return None

    # Step 2: is it a technical diagram convertible to mermaid?
    is_diagram = vision_complete(image_bytes, media_type,
        "Is this a technical diagram (flowchart, sequence diagram, architecture chart, "
        "state machine, entity relationship diagram, etc.) that could be expressed as "
        "Mermaid syntax? Answer only 'yes' or 'no'.", max_tokens=10)
    if is_diagram and is_diagram.strip().lower().startswith('y'):
        with open(img_path, "wb") as f:
            f.write(image_bytes)
        mermaid = vision_complete(image_bytes, media_type,
            "Convert this diagram to Mermaid syntax. Output only the raw mermaid code "
            "(no ```mermaid fences, no explanation).", max_tokens=2048)
        if mermaid:
            mermaid = mermaid.strip()
            if mermaid.startswith("```"):
                lines = mermaid.splitlines()
                inner = lines[1:-1] if lines[-1].strip() == "```" else lines[1:]
                mermaid = "\n".join(inner)
            print(f"  Diagram -> mermaid: {img_filename}", file=sys.stderr)
            return f"![{img_filename}]({img_filename})\n\n```mermaid\n{mermaid}\n```"

    # Not a diagram — convert to markdown text/tables instead of saving as image
    md_text = vision_complete(image_bytes, media_type,
        "Convert this image to clean markdown. "
        "If it contains one or more tables, use GitHub-flavored markdown table syntax. "
        "If it contains text or lists, preserve them as markdown. "
        "Output ONLY the markdown content, no preamble or explanation.",
        max_tokens=4096)
    if md_text and md_text.strip():
        print(f"  Converted to markdown: {img_filename}", file=sys.stderr)
        return md_text.strip()

    # Fallback: save as image if conversion produced nothing
    with open(img_path, "wb") as f:
        f.write(image_bytes)
    print(f"  Image saved: {img_filename}", file=sys.stderr)
    return f"![{img_filename}]({img_filename})"

for page_num, page in enumerate(doc):
    # Process embedded raster images (photos, screenshots, etc.)
    for img_idx, img_info in enumerate(page.get_images(full=True)):
        xref = img_info[0]
        try:
            base_image = doc.extract_image(xref)
        except Exception as e:
            print(f"  Warning: could not extract image p{page_num+1} img{img_idx+1}: {e}", file=sys.stderr)
            continue

        image_bytes = base_image["image"]
        w = base_image.get("width", 0)
        h = base_image.get("height", 0)
        if w * h < MIN_IMAGE_AREA:
            continue  # skip tiny icons/artifacts

        image_ext = base_image.get("ext", "png")
        img_filename = f"{base_name}_p{page_num+1}_img{img_idx+1}.{image_ext}"
        img_path = os.path.join(output_dir, img_filename)
        media_type = "image/jpeg" if image_ext in ("jpg", "jpeg") else f"image/{image_ext}"
        result = classify_and_convert(image_bytes, media_type, img_filename, img_path)
        if result is not None:
            page_images.setdefault(page_num + 1, []).append(result)

    # Process vector drawings: skip if page already has raster images (avoids duplicates)
    if (page_num + 1) in page_images:
        continue
    drawings = page.get_drawings()
    if len(drawings) >= DRAWING_THRESHOLD:
        # Compute bounding box of all drawings on this page
        rects = [d["rect"] for d in drawings if d.get("rect")]
        if rects:
            x0 = min(r.x0 for r in rects)
            y0 = min(r.y0 for r in rects)
            x1 = max(r.x1 for r in rects)
            y1 = max(r.y1 for r in rects)
            # Skip drawing regions that are too narrow/short to be real diagrams
            page_rect = page.rect
            if (x1 - x0) < page_rect.width * 0.15 or (y1 - y0) < page_rect.height * 0.15:
                continue
            clip = pymupdf.Rect(x0, y0, x1, y1)
            pix = page.get_pixmap(dpi=150, clip=clip)
            img_filename = f"{base_name}_p{page_num+1}_drawing.png"
            img_path = os.path.join(output_dir, img_filename)
            image_bytes = pix.tobytes("png")
            result = classify_and_convert(image_bytes, "image/png", img_filename, img_path)
            if result is not None:
                page_images.setdefault(page_num + 1, []).append(result)

doc.close()

if not page_images:
    sys.exit(0)

# Insert images inline after their page's text, then strip page markers
import re

with open(output_file, "r", encoding="utf-8") as f:
    content = f.read()

remaining = dict(page_images)
segments = re.split(r'(<!-- page-\d+ -->)', content)
result_parts = []
current_page = None
for seg in segments:
    m = re.match(r'<!-- page-(\d+) -->', seg)
    if m:
        current_page = int(m.group(1))
        # Drop the marker from output
    else:
        result_parts.append(seg)
        if current_page is not None and current_page in remaining:
            for img_md in remaining.pop(current_page):
                result_parts.append(f"\n\n{img_md}\n\n")

# Any images whose page marker wasn't found: append at end
for pnum in sorted(remaining.keys()):
    for img_md in remaining[pnum]:
        result_parts.append(f"\n\n{img_md}\n\n")

with open(output_file, "w", encoding="utf-8") as f:
    f.write("".join(result_parts))
IMAGE_PYEOF
else
    echo -e "  ${YELLOW}Tip: Set ANTHROPIC_API_KEY for diagram detection in images${NC}"
fi

if [[ -f "$OUTPUT_FILE" ]] && [[ -s "$OUTPUT_FILE" ]]; then
    echo -e "${GREEN}✓ Markdown created successfully: $OUTPUT_FILE${NC}"

    if [[ -n "$OCR_USED" ]]; then
        echo -e "  ${YELLOW}(used OCR — image-based PDF detected)${NC}"
    fi

    # Show file info
    SIZE=$(ls -lh "$OUTPUT_FILE" | awk '{print $5}')
    LINES=$(wc -l < "$OUTPUT_FILE" | tr -d ' ')
    echo -e "  Size: $SIZE, Lines: $LINES"
else
    echo -e "${RED}✗ Failed to create Markdown${NC}"
    exit 1
fi
